# to list & modify interfaces on host
ip link

## to view ip address to those interfaces
ip addr


## To set ip address to interfaces
ip addr add 192.168.1.10/24 dev etho

##To see the existing routing table on the host system.

ip route

ip route add 192.168.1.0/24 via 192.168.2.1

##To check the IP forwarding is enabled on the host.

cat /proc/sys/net/ipv4-forward

###Enable packet forwarding for IPv4.
$ cat /etc/sysctl.conf
# Uncomment the line
net.ipv4.ip_forward=1

To view the sysctl variables.
$ sysctl -a 
To reload the sysctl configuration.
$ sysctl --system

